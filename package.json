{
  "name": "obsidian-aloud-tts-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace for Aloud TTS",
  "scripts": {
    "all": "pnpm lint && pnpm format:check && pnpm test && pnpm build",
    "dev": "pnpm --filter obsidian-aloud-tts dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "pnpm --filter open-tts build && pnpm --filter @open-tts/ui build && pnpm --filter obsidian-aloud-tts build && pnpm --filter @open-tts/web build && pnpm --filter ./docs build",
    "obsidian:build": "pnpm --filter obsidian-aloud-tts build",
    "version": "./version-bump.sh",
    "lint": "eslint packages test-setup.ts playwright.config.ts vitest.config.ts",
    "test": "vitest run",
    "format:check": "prettier --check packages test-setup.ts playwright.config.ts vitest.config.ts",
    "format": "prettier --write packages test-setup.ts playwright.config.ts vitest.config.ts",
    "web:dev": "pnpm --filter @open-tts/web dev",
    "web:build": "pnpm --filter @open-tts/web build",
    "docs:build": "pnpm --filter ./docs build",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "keywords": [
    "obsidian",
    "text-to-speech"
  ],
  "author": "Adrian Lyjak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianlyjak/obsidian-aloud-tts"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "6.13.2",
    "@typescript-eslint/parser": "6.13.2",
    "@vitest/coverage-v8": "3.2.4",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.25.4",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.2.11",
    "obsidian": "^1.7.2",
    "prettier": "^3.3.3",
    "tslib": "2.6.2",
    "typescript": "5.3.2",
    "vite": "^6.3.5",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vitest": "^3.1.3"
  },
  "packageManager": "pnpm@9.0.2+sha1.2a34aeb80bf8e8435815d14f620ec4ba0eff1604",
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "prettier --check",
      "eslint"
    ]
  },
  "pnpm": {
    "overrides": {
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "nanoid@<3.3.8": ">=3.3.8",
      "elliptic@<6.6.0": ">=6.6.0",
      "esbuild@<=0.24.2": ">=0.25.0",
      "vitest@>=1.0.0 <1.6.1": ">=1.6.1",
      "vite@>=5.0.0 <=5.4.11": ">=5.4.12",
      "elliptic@<=6.6.0": ">=6.6.1",
      "vite@>=5.0.0 <5.4.15": ">=5.4.15",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "pbkdf2@<=3.1.2": ">=3.1.3",
      "pbkdf2@>=3.0.10 <=3.1.2": ">=3.1.3",
      "vite@>=6.0.0 <=6.3.5": ">=6.3.6",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
      "sha.js@<=2.4.11": ">=2.4.12",
      "cipher-base@<=1.0.4": ">=1.0.5",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "jws@=4.0.0": ">=4.0.1"
    }
  }
}
