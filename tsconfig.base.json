{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "jsx": "react",
    "lib": ["DOM", "ES5", "ES6", "ES7"],
    "skipLibCheck": true,
    "paths": {
      "open-tts": ["packages/open-tts/src/index.ts"],
      "open-tts/browser": ["packages/open-tts/src/browser/index.ts"],
      "@open-tts/ui": ["packages/ui/src/index.ts"]
    }
  }
}
